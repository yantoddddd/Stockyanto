{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/webhook.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/order/(.*)",
      "dest": "public/order.html"
    },
    {
      "src": "/admin",
      "dest": "public/admin.html"
    },
    {
      "src": "/unauthorized",
      "dest": "public/unauthorized.html"
    },
    {
      "src": "/ketentuan",
      "dest": "public/ketentuan.html"
    },
    { 
      "src": "/gacha",
      "dest": "public/gacha.html"
    },
    { 
      "src": "/profile", 
      "dest": "public/profile.html" 
    }
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
